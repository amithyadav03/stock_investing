# --- [PRIMARY AI: CLAUDE / ANTHROPIC] ---
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# --- [OPTIONAL LEGACY LLM] ---
OPENAI_API_KEY="your-openai-api-key-here"
GEMINI_API_KEY="your-gemini-api-key-here"

# --- [BROKER: ZERODHA KITE CONNECT] ---
# From https://kite.trade/
KITE_API_KEY="your-kite-api-key-here"
KITE_API_SECRET="your-kite-api-secret-here"
# IMPORTANT: Kite Access Tokens expire daily at 6 AM IST.
# Run `python -m core.auth` each morning to refresh.
KITE_ACCESS_TOKEN="your-daily-access-token-here"

# --- [TELEGRAM] ---
# Create bot via @BotFather, get chat_id via @userinfobot
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-personal-chat-id"

# --- [NGROK — Local Webhook Tunnel] ---
NGROK_AUTH_TOKEN="your-ngrok-auth-token"

# --- [LANGFUSE OBSERVABILITY] (optional) ---
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_HOST="https://cloud.langfuse.com"

# --- [DATABASE] ---
DATABASE_URL="sqlite:///./db/trading.db"
CHROMA_DB_DIR="./db/chroma_memory"
