# ==============================================================================
# AI SWING TRADING AGENT - ENVIRONMENT SECRETS TEMPLATE
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this file to a new file named `.env`
# 2. Fill in your actual keys for each variable below.
# 3. DO NOT commit your actual `.env` file to any version control (Git).
# ==============================================================================

# --- [LLM SERVICE CONFIGURATION] ---
# Primary AI reasoning engine. GPT-4o or GPT-4o-mini is highly recommended.
OPENAI_API_KEY="your-openai-api-key-here"

# Optional: Google Gemini fallback for extremely large text context windows.
GEMINI_API_KEY="your-gemini-api-key-here"


# --- [BROKER CONFIGURATION: ZERODHA KITE CONNECT] ---
# Get these from your Kite Connect developer dashboard.
KITE_API_KEY="your-kite-api-key-here"
KITE_API_SECRET="your-kite-api-secret-here"

# IMPORTANT: Kite Access Tokens expire daily at 6:00 AM IST.
# Generate a new one each morning via `python -m core.auth` and paste it here.
KITE_ACCESS_TOKEN="your-daily-access-token-here"


# --- [TELEGRAM BOT & NOTIFICATIONS] ---
# Bot Token: Get this from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN="your-telegram-bot-token-here"

# Chat ID: Your personal ID or the Group ID where signals should be sent.
TELEGRAM_CHAT_ID="your-telegram-chat-id-here"


# --- [LOCAL TESTING: NGROK TUNNEL] ---
# Required for Telegram to reach your local machine during development.
# Sign up free at https://ngrok.com and get your auth token.
NGROK_AUTH_TOKEN="your-ngrok-auth-token-here"


# --- [DATABASE & PERSISTENT STORAGE] ---
# Path to your SQLite trading database.
DATABASE_URL="sqlite:///./db/trading.db"

# Directory for ChromaDB vector storage (for AI long-term trading memory).
CHROMA_DB_DIR="./db/chroma_memory"

# ==============================================================================
# END OF TEMPLATE
# ==============================================================================
