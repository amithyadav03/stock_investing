# ==============================================================================
# ALPHA AGENT — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values.
# ==============================================================================

# ── REQUIRED FOR BACKTESTING (only this section needed) ───────────────────────
# Nothing! The backtest uses yfinance (free) and SQLite (local).
# Just run: python -m backtest.run_scenarios
# No API keys needed for backtesting.


# ── REQUIRED FOR LIVE AGENT (paper or real trading) ───────────────────────────

# Claude AI — get from console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram bot — get from @BotFather on Telegram
# Step 1: Message @BotFather → /newbot → follow prompts → copy token
# Step 2: Message your bot, then visit:
#   https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#   to find your chat_id (look for "chat":{"id":XXXXXXX})
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Webhook security — any random string, e.g.: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=your_random_secret_here


# ── REQUIRED FOR LIVE KITE TRADING (not needed for paper mode) ────────────────
# Get from developers.kite.trade → your app → API key + secret
KITE_API_KEY=your_kite_api_key_here
KITE_API_SECRET=your_kite_api_secret_here
# Access token refreshes every day — see docs/kite_auth.md for automation
KITE_ACCESS_TOKEN=your_daily_access_token_here


# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# Database (defaults to local SQLite — fine for personal use)
DATABASE_URL=sqlite:///./db/trading.db

# Langfuse observability (optional — leave blank to skip)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=

# Ngrok (only needed if you want Telegram webhooks on local machine)
NGROK_AUTH_TOKEN=
